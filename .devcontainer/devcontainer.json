{
  "name": "Pants Dev Container",
  "build": {
    "context": ".",
    "dockerfile": "./Dockerfile"
  },
  "features": {
    // DinD feature mounts `/tmp` to `tmpfs` by default, limiting the `/tmp` folder
    // size to the amount of RAM that is available, which results in `Out of space
    // Exception` when Pants runs. Temporary fix until issue #471 is resolved.
    // See: https://github.com/devcontainers/features/issues/471
    "ghcr.io/erjac77/devcontainers-features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": 3.9
    },
    "ghcr.io/stuartleeks/dev-container-features/shell-history:0": {}
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.analysis.extraPaths": ["src/python"],
        "python.formatting.provider": "ms-python.black-formatter",
        "python.linting.enabled": true,
        "python.linting.flake8Enabled": true,
        "python.linting.flake8Args": ["--config=build-support/flake8/.flake8"],
        "rust-analyzer.linkedProjects": ["src/rust/engine/Cargo.toml"]
      },
      "extensions": [
        // Installed by the Python feature:
        // "ms-python.python",
        // "ms-python.vscode-pylance",
        // "ms-python.autopep8",
        "ms-python.black-formatter",
        "vadimcn.vscode-lldb",
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml"
      ]
    }
  },
  "remoteUser": "vscode",
  // Pants cache directories. No need to mount `$HOME/.cache/nce` (cache directory
  // used by the Pants launcher binary) since de development workflow invokes Pants
  // directly from the sources using a different runner script.
  // See: https://www.pantsbuild.org/stable/docs/using-pants/using-pants-in-ci#directories-to-cache
  // See: https://www.pantsbuild.org/stable/docs/contributions/development/running-pants-from-sources
  "mounts": [
    {
      "source": "pants-named_caches",
      "target": "/home/vscode/.cache/pants/named_caches",
      "type": "volume"
    },
    {
      "source": "pants-lmdb_store",
      "target": "/home/vscode/.cache/pants/lmdb_store",
      "type": "volume"
    }
  ],
  "postCreateCommand": ".devcontainer/postCreateCommand.sh"
}
